{% comment %} prepare and display current average rating {% endcomment %}

{% assign avg_rating_raw = product.metafields.reviews.average_rating.value %}
{% comment %} Ensure avg_rating is a number {% endcomment %}
{% assign avg_rating = avg_rating_raw | times: 1 %} 

{% comment %} Get total review count {% endcomment %}
{% assign total_ratings = product.metafields.reviews.total_ratings.value | times: 1 | default: 0 %}

{% assign is_rated = false %}

{% comment %} Check if custom.star_ratings metafield has content {% endcomment %}
{% assign raw_ratings_json = product.metafields.custom.star_ratings.value %}

{% if raw_ratings_json != blank and raw_ratings_json != "[]" %}
  {% assign is_rated = true %}
{% endif %}

{% comment %} star rating widget {% endcomment %}
<div id="star-rating-container-{{ product.id }}" class="star-rating-container">
  <div
    id="star-rating-widget-{{ product.id }}"
    class="star-rating-widget"
    data-product-id="{{ product.id }}"
    data-initial-rating="{{ rounded_avg_rating }}"
  >
    
 {% comment %} calculate average for display/initial color setting {% endcomment %}
{% assign rounded_avg_rating = avg_rating | round %}

<span id="star-display-{{ product.id }}" class="interactive-stars">
    {% for i in (1..5) %}
        
        {% comment %} star styling {% endcomment %}
      {% assign star_color = '#ccc' %}
      {% if is_rated and i <= rounded_avg_rating %}
        {% assign star_color = '#F7BC45' %}
      {% endif %}

      <span class="star-vote" 
            data-rating="{{ i }}" 
            style="color: {{ star_color }};" 
      >★</span>
    {% endfor %}

    <span id="vote-count-{{ product.id }}" class="rating-count-text" style="margin-left: 5px;">
        {% if is_rated %}
            {{ avg_rating | round: 1 }} ({{ total_ratings }} reviews)
        {% endif %}
    </span>
</span>
    
  

  </div>

  <p id="rating-message-{{ product.id }}"></p>
</div>

<script>
  // star rating functionality 
  document.addEventListener('DOMContentLoaded', () => {
    const productId = {{ product.id }};
    const widgetElement = document.getElementById(`star-rating-widget-${productId}`);
    const messageElement = document.getElementById(`rating-message-${productId}`);
    const initialRatingElement = widgetElement.getAttribute('data-initial-rating');
    const initialRating = initialRatingElement ? parseInt(initialRatingElement) : 0;
    
    // rating functionality
    const starDisplayElement = widgetElement.querySelector('#star-display-' + productId);
    const stars = starDisplayElement ? starDisplayElement.querySelectorAll('.star-vote') : [];
    
    if (stars.length === 0) return;

    // star hover effects 
    stars.forEach(star => {
      // star hover mouseover
      star.addEventListener('mouseover', (e) => {
          const ratingValue = parseInt(e.target.dataset.rating);
          stars.forEach(s => {
              s.style.color = parseInt(s.dataset.rating) <= ratingValue ? '#F7BC45' : '#ccc'; 
          });
      });
      
      // reset stars to average rating on initial load/reload
      star.addEventListener('mouseout', () => {
          stars.forEach(s => {
              s.style.color = parseInt(s.dataset.rating) <= parseInt(widgetElement.getAttribute('data-initial-rating')) ? '#F7BC45' : '#ccc'; 
          });
      });

      // click listener for rating submission
      star.addEventListener('click', async (e) => {
        const rating = e.target.dataset.rating;
        starDisplayElement.style.pointerEvents = 'none'; 
        
        try {
          const response = await fetch('https://reviews-widget-production.up.railway.app/submit-rating', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ productId: productId.toString(), rating: parseInt(rating) })
          });

          if (response.ok) {
              const data = await response.json();
              const newAverage = parseFloat(data.newAvgRating); 
              const totalReviews = parseInt(data.totalRatings); 
              messageElement.textContent = 'Thanks for rating!';
              
              // update star display
              const roundedRating = Math.round(newAverage);
              
              stars.forEach(s => {
                  s.style.color = parseInt(s.dataset.rating) <= roundedRating ? '#F7BC45' : '#ccc';
              });
              
              widgetElement.setAttribute('data-initial-rating', roundedRating);
              
              // update average text 
              const voteCountElement = widgetElement.querySelector('#vote-count-' + productId);
              if (voteCountElement) {
                 voteCountElement.textContent = `${newAverage.toFixed(1)} (${totalReviews} review${totalReviews !== 1 ? 's' : ''})`;
              }

          } else {
            const errorDetails = await response.text();
            messageElement.textContent = `Submission failed. Error: ${errorDetails.substring(0, 50)}...`;
            starDisplayElement.style.pointerEvents = 'auto'; // Re-enable clicks on failure
          }
        } catch (error) {
          messageElement.textContent = `Network error during submission: ${error.message}`;
          starDisplayElement.style.pointerEvents = 'auto'; // Re-enable clicks on failure
        }
      });
    });
  });
</script>